import math
import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D  # Needed for 3D plotting

class BioreactorGeometry:
    def __init__(self, diameter_m, height_m, cone_height_m=0.0):
        if diameter_m <= 0 or height_m <= 0 or cone_height_m < 0:
            raise ValueError("Dimensions must be positive, cone height can be zero.")
        
        self.diameter = diameter_m
        self.height = height_m
        self.cone_height = cone_height_m

    def cylinder_volume(self):
        radius = self.diameter / 2
        return math.pi * radius**2 * self.height

    def cone_volume(self):
        if self.cone_height == 0:
            return 0.0
        radius = self.diameter / 2
        return (1/3) * math.pi * radius**2 * self.cone_height

    def total_volume(self):
        return self.cylinder_volume() + self.cone_volume()

    def surface_area(self):
        radius = self.diameter / 2
        side_area = 2 * math.pi * radius * self.height
        top_area = math.pi * radius**2
        cone_area = 0.0
        if self.cone_height > 0:
            slant_height = math.sqrt(radius**2 + self.cone_height**2)
            cone_area = math.pi * radius * slant_height
        return side_area + top_area + cone_area

    def plot_geometry(self):
        """3D visualization of the bioreactor."""
        radius = self.diameter / 2

        fig = plt.figure(figsize=(8, 6))
        ax = fig.add_subplot(111, projection='3d')

        # Cylinder
        z_cyl = np.linspace(self.cone_height, self.cone_height + self.height, 50)
        theta = np.linspace(0, 2 * np.pi, 50)
        theta_grid, z_grid = np.meshgrid(theta, z_cyl)
        x_cyl = radius * np.cos(theta_grid)
        y_cyl = radius * np.sin(theta_grid)
        ax.plot_surface(x_cyl, y_cyl, z_grid, color='skyblue', alpha=0.7)

        # Cone
        if self.cone_height > 0:
            z_cone = np.linspace(0, self.cone_height, 50)
            r_cone = radius * (z_cone / self.cone_height)
            theta_grid, z_grid = np.meshgrid(theta, z_cone)
            x_cone = r_cone * np.cos(theta_grid)
            y_cone = r_cone * np.sin(theta_grid)
            ax.plot_surface(x_cone, y_cone, z_grid, color='lightgreen', alpha=0.7)

        # Top disk
        x_top = radius * np.cos(theta)
        y_top = radius * np.sin(theta)
        z_top = np.full_like(x_top, self.cone_height + self.height)
        ax.plot_trisurf(x_top, y_top, z_top, color='steelblue', alpha=0.8)

        # Labels and view
        ax.set_xlabel("X (m)")
        ax.set_ylabel("Y (m)")
        ax.set_zlabel("Height (m)")
        ax.set_title("3D Bioreactor Geometry")
        ax.view_init(elev=20, azim=30)
        plt.tight_layout()
        plt.show()


# Example usage
if __name__ == "__main__":
    try:
        reactor = BioreactorGeometry(diameter_m=5.421, height_m=1.6*5.421, cone_height_m=0)
        
        print(f"Cylindrical volume: {reactor.cylinder_volume():.3f} m³")
        print(f"Conical volume: {reactor.cone_volume():.3f} m³")
        print(f"Total volume: {reactor.total_volume():.3f} m³")
        print(f"Surface area: {reactor.surface_area():.3f} m²")
        
        reactor.plot_geometry()
    except ValueError as e:
        print(f"Error: {e}")
